REPO=Kerrycek/clankerdev
REPO_URL=git@github.com:Kerrycek/clankerdev.git
BASE_BRANCH=main
WORKDIR=/srv/clankerdev-ai/worktree
STATE_DIR=/var/lib/clankerdev-ai
LOG_DIR=/var/log/clankerdev-ai
ISSUE_LABEL=ai-fix
IN_PROGRESS_LABEL=ai-in-progress
DONE_LABEL=ai-pr
FAILED_LABEL=ai-failed
# Optional: leave empty to use the Codex CLI default model.
CODEX_MODEL=
CODEX_SANDBOX=workspace-write
CODEX_APPROVAL=never
