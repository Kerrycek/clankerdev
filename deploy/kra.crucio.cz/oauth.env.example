# WebUI Next OAuth BFF env for kra.crucio.cz.
# This host serves the same frontend build as dev.crucio.cz, but points to the
# original vpsFree API and OAuth endpoints.

DOMAIN=kra.crucio.cz
PORT=3002

API_URL=https://api.vpsfree.cz
API_VERSION=7.0
HAVEAPI_AUTH_HEADER=X-HaveAPI-OAuth2-Token
HAVEAPI_META_NAMESPACE=_meta

OAUTH_AUTHORIZE_URL=https://auth.vpsfree.cz/_auth/oauth2/authorize
OAUTH_TOKEN_URL=https://auth.vpsfree.cz/_auth/oauth2/token
OAUTH_REVOKE_URL=https://auth.vpsfree.cz/_auth/oauth2/revoke

# Use an OAuth client that permits https://kra.crucio.cz/oauth/callback.
# During the initial preview this can use the same client as the original
# clankerdev.vpsfree.cz deployment if that client allows the kra callback.
OAUTH_CLIENT_ID=clankerdev.vpsfree.cz
OAUTH_CLIENT_SECRET=change-me
OAUTH_REDIRECT_URI=https://kra.crucio.cz/oauth/callback
OAUTH_SCOPE=all
OAUTH_TYPE=web_server

SESSION_SECRET=change-me
SESSION_STORE_PATH=/var/lib/webui-next-bff-kra/sessions
SESSION_COOKIE_NAME=webui_next_kra_sess

