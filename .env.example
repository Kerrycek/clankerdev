# Copy this file to `.env.local` (recommended) or `.env` and fill in your values.
#
# IMPORTANT:
# - Do NOT commit `.env.local` or `.env` with real tokens.
# - Vite only exposes variables prefixed with `VITE_`.

# API endpoint
VITE_API_URL=https://api.vpsfree.cz
VITE_API_VERSION=7.0

# OPTIONAL (dev): avoid CORS by proxying API calls through the Vite dev server.
#
# How it works:
#   - set VITE_API_URL=/api (so frontend calls same-origin /api/v7.0/...)
#   - set VITE_API_PROXY_TARGET to the real API origin
#
# Example:
#   VITE_API_URL=/api
#   VITE_API_PROXY_TARGET=https://api.internal.example
#
# VITE_API_PROXY_TARGET=https://api.vpsfree.cz
# VITE_API_PROXY_PREFIX=/api
# VITE_API_PROXY_SECURE=true

# Optional: base URL of the legacy web UI (used for login/logout links)
# VITE_WEBUI_URL=https://vpsadmin.vpsfree.cz

# Optional: explicit login/logout endpoints (overrides legacy /?page=login, /?page=logout)
# VITE_LOGIN_URL=/login
# VITE_LOGOUT_URL=/logout

# OAuth2 (SSO)
#
# The SPA uses vpsFree's OAuth2 to obtain an access token and then calls the API directly.
#
# Defaults:
# - client_id: current hostname (window.location.hostname)
# - redirect path: `${VITE_ROUTER_BASENAME}/oauth/callback`
# - scope: all
# - flow: pkce
# - storage: session
#
# You normally only need to set VITE_OAUTH2_CLIENT_ID when the hostname differs
# from the registered OAuth2 client_id.
#
# VITE_OAUTH2_AUTHORIZE_URL=https://auth.vpsfree.cz/_auth/oauth2/authorize
# VITE_OAUTH2_TOKEN_URL=https://auth.vpsfree.cz/_auth/oauth2/token
# VITE_OAUTH2_CLIENT_ID=clankerdev.vpsfree.cz
# VITE_OAUTH2_SCOPE=all
# VITE_OAUTH2_TYPE=web_server
# VITE_OAUTH2_FLOW=pkce
# VITE_OAUTH2_REDIRECT_PATH=/oauth/callback
# VITE_OAUTH2_STORAGE=session

# OPTIONAL: Serve the SPA under a sub-path (router basename)
# Example: https://vpsadmin.example.cz/ui-next/
# VITE_ROUTER_BASENAME=/ui-next

# OPTIONAL (dev): if you run standalone without window.vpsAdmin.description,
# you can force the HaveAPI auth header name.
# VITE_HAVEAPI_AUTH_HEADER=X-HaveAPI-Auth-Token
# VITE_HAVEAPI_META_NAMESPACE=_meta

# OPTIONAL (dev): expose Vite server on internal network
# VITE_DEV_HOST=0.0.0.0
# VITE_DEV_PORT=5173

# OPTIONAL (dev): enable HTTPS in Vite server (paths to key/cert files)
# VITE_DEV_HTTPS=true
# VITE_DEV_HTTPS_KEY=./certs/dev.key
# VITE_DEV_HTTPS_CERT=./certs/dev.crt

# UI settings persistence (optional)
# VITE_UI_SETTINGS_PERSISTENCE=local
# VITE_UI_SETTINGS_PERSISTENCE=server
# VITE_UI_SETTINGS_SERVER_PATH=/user_sessions/current/ui_setting
# VITE_UI_SETTINGS_NAMESPACE=ui_setting
# VITE_UI_SETTINGS_FIELD=settings

# Internal feature flags

# Enable the Design Sandbox in production builds.
# (Dev builds enable it automatically.)
# VITE_ENABLE_DESIGN_SANDBOX=1